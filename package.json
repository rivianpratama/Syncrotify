{
  "name": "syncrotify",
  "version": "2.0.0",
  "description": "Sync YouTube Music playlists to folders, MP3 players, and iPods.",
  "author": "Syncrotify contributors",
  "main": "dist-electron/electron/main.js",
  "type": "module",
  "scripts": {
    "dev": "concurrently -k \"vite\" \"wait-on tcp:5173 && cross-env VITE_DEV_SERVER_URL=http://localhost:5173 electron .\"",
    "build": "node scripts/clean_electron.mjs && tsc -b && vite build && tsc -p electron/tsconfig.json",
    "build:backend": "python scripts/build_backend.py",
    "prepare:resources": "python scripts/prepare_resources.py",
    "test": "vitest run",
    "test:python": "python -m unittest discover -s tests -v",
    "check": "npm run test && npm run test:python && npm run build",
    "package:win": "npm run prepare:resources && npm run build:backend && npm run build && electron-builder --win nsis portable --x64",
    "package:mac": "npm run prepare:resources && npm run build:backend && npm run build && electron-builder --mac dmg zip --x64 --arm64"
  },
  "dependencies": {
    "lucide-react": "^0.468.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@types/node": "^22.10.2",
    "@types/react": "^19.0.2",
    "@types/react-dom": "^19.0.2",
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.1.0",
    "cross-env": "^7.0.3",
    "deno-bin": "^2.2.7",
    "electron": "^33.2.1",
    "electron-builder": "^25.1.8",
    "typescript": "~5.7.2",
    "vite": "^6.0.3",
    "vitest": "^2.1.8",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.syncrotify.desktop",
    "productName": "Syncrotify",
    "asar": true,
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**",
      "dist-electron/**",
      "package.json"
    ],
    "extraResources": [
      {
        "from": "resources/backend",
        "to": "backend",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "resources/bin",
        "to": "bin",
        "filter": [
          "**/*"
        ]
      },
      {
        "from": "THIRD_PARTY_NOTICES.md",
        "to": "THIRD_PARTY_NOTICES.md"
      },
      {
        "from": "resources/icons/icon.png",
        "to": "icon.png"
      }
    ],
    "win": {
      "icon": "resources/icons/icon.ico",
      "target": [
        "nsis",
        "portable"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "artifactName": "${productName}-Setup-${version}-${arch}.${ext}"
    },
    "portable": {
      "artifactName": "${productName}-Portable-${version}-${arch}.${ext}"
    },
    "mac": {
      "icon": "resources/icons/icon.icns",
      "category": "public.app-category.music",
      "artifactName": "${productName}-${version}-${arch}.${ext}",
      "hardenedRuntime": false,
      "gatekeeperAssess": false,
      "target": [
        "dmg",
        "zip"
      ]
    }
  }
}